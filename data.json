  "kpis": {
    "definitions": [
      {
        "id": "conversion_rate_quoted",
        "name": "Conversion Rate (Quoted \u2192 Confirmed)",
        "unit": "%",
        "direction": "higher",
        "defaultWeight": 0.25,
        "formula": "bookingsConfirmed / bookingsQuoted"
      },
      {
        "id": "call_rate",
        "name": "Call Rate (Quotes with Call/VM Attached)",
        "unit": "%",
        "direction": "higher",
        "defaultWeight": 0.15,
        "formula": "quotesWithCall / totalQuotes",
        "draft": true
      },
      {
        "id": "revenue_target",
        "name": "Revenue vs Target",
        "unit": "AUD",
        "direction": "higher",
        "defaultWeight": 0.2
      },
      {
        "id": "margin_target",
        "name": "Realised Margin vs Target",
        "unit": "%",
        "direction": "higher",
        "defaultWeight": 0.15
      },
      {
        "id": "client_satisfaction",
        "name": "Client Satisfaction",
        "unit": "/10",
        "direction": "higher",
        "defaultWeight": 0.1
      },
      {
        "id": "bookings_on_time",
        "name": "Bookings Delivered On-Time",
        "unit": "%",
        "direction": "higher",
        "defaultWeight": 0.1
      },
      {
        "id": "complaint_rate",
        "name": "Complaint Rate",
        "unit": "%",
        "direction": "lower",
        "defaultWeight": 0.05
      },
      {
        "id": "team_engagement",
        "name": "Team Engagement (GM only)",
        "unit": "score",
        "direction": "higher",
        "defaultWeight": 0.1
      }
    ]
  },
